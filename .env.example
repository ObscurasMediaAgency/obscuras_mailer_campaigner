# ═══════════════════════════════════════════════════════════════════
# Obscuras Mail Campaign – Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Dann: source .env (oder export manuell)

# SMTP Server Einstellungen
export SMTP_HOST="smtp.deinserver.de"
export SMTP_PORT="465"
export SMTP_USER="mail@obscuras-media-agency.de"
export SMTP_PASS="dein-sicheres-passwort"

# Absender (optional)
export FROM_EMAIL="mail@obscuras-media-agency.de"
