<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{EMAIL_SUBJECT}}</title>
</head>
<body style="margin:0;padding:0;background-color:#ffffff;font-family:Georgia,'Times New Roman',serif;">

<!-- WRAPPER -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#ffffff;padding:40px 20px;">
  <tr>
    <td align="center">

      <!-- MAIN CONTAINER -->
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">

        <!-- HEADER -->
        <tr>
          <td style="padding:20px 0 30px;border-bottom:2px solid #1a1a1a;">
            {% if LOGO_URL %}
            <img src="{{LOGO_URL}}" alt="{{COMPANY_NAME}}" style="display:block;max-height:50px;margin-bottom:10px;">
            {% else %}
            <p style="margin:0;color:#1a1a1a;font-size:24px;font-weight:bold;">{{COMPANY_NAME}}</p>
            {% endif %}
          </td>
        </tr>

        <!-- CONTENT -->
        <tr>
          <td style="padding:40px 0;">

            <!-- GREETING -->
            {% if CONTENT_GREETING %}
            <p style="margin:0 0 24px;color:#1a1a1a;font-size:18px;line-height:1.6;">
              {{CONTENT_GREETING}}
            </p>
            {% endif %}

            <!-- INTRO -->
            {% if CONTENT_INTRO %}
            <p style="margin:0 0 20px;color:#333333;font-size:16px;line-height:1.8;">
              {{CONTENT_INTRO}}
            </p>
            {% endif %}

            <!-- BODY -->
            <div style="color:#333333;font-size:16px;line-height:1.8;">
              {{CONTENT_BODY}}
            </div>

            <!-- CTA -->
            {% if CONTENT_CTA_URL and CONTENT_CTA_TEXT %}
            <p style="margin:30px 0;">
              <a href="{{CONTENT_CTA_URL}}" 
                 style="color:#1a1a1a;font-size:16px;font-weight:bold;text-decoration:underline;">
                → {{CONTENT_CTA_TEXT}}
              </a>
            </p>
            {% endif %}

            <!-- SIGNATURE -->
            <table cellpadding="0" cellspacing="0" border="0" style="margin-top:40px;padding-top:20px;border-top:1px solid #e5e5e5;">
              <tr>
                <td>
                  <p style="margin:0 0 4px;color:#1a1a1a;font-size:16px;">Mit freundlichen Grüßen,</p>
                  <p style="margin:16px 0 4px;color:#1a1a1a;font-size:16px;font-weight:bold;">{{SENDER_NAME}}</p>
                  {% if SENDER_TITLE %}
                  <p style="margin:0;color:#666666;font-size:14px;">{{SENDER_TITLE}}</p>
                  {% endif %}
                </td>
              </tr>
            </table>

          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td style="padding:20px 0;border-top:1px solid #e5e5e5;">
            <p style="margin:0;color:#999999;font-size:12px;line-height:1.6;">
              {{COMPANY_NAME}}
              {% if COMPANY_ADDRESS %} · {{COMPANY_ADDRESS}}{% endif %}<br>
              {% if COMPANY_URL %}
              <a href="{{COMPANY_URL}}" style="color:#666666;">{{COMPANY_DOMAIN}}</a>
              {% endif %}
            </p>
            <p style="margin:12px 0 0;color:#999999;font-size:11px;">
              {% if COMPANY_URL %}
              <a href="{{COMPANY_URL}}/impressum" style="color:#999999;">Impressum</a> · 
              <a href="{{COMPANY_URL}}/datenschutz" style="color:#999999;">Datenschutz</a>
              {% endif %}
              {% if UNSUBSCRIBE_URL %}
               · <a href="{{UNSUBSCRIBE_URL}}" style="color:#999999;">Newsletter abbestellen</a>
              {% endif %}
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>

</body>
</html>
