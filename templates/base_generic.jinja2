<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{EMAIL_SUBJECT}}</title>
<!--[if mso]>
<style type="text/css">
  table {border-collapse: collapse;}
  .mso-button {padding: 14px 32px !important;}
</style>
<![endif]-->
</head>
<body style="margin:0;padding:0;background-color:{{THEME_BG_COLOR|default('#f4f4f5')}};font-family:'Segoe UI',Roboto,Arial,sans-serif;-webkit-font-smoothing:antialiased;">

<!-- WRAPPER -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:{{THEME_BG_COLOR|default('#f4f4f5')}};padding:40px 20px;">
  <tr>
    <td align="center">

      <!-- MAIN CONTAINER -->
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">

        <!-- LOGO HEADER -->
        {% if LOGO_URL %}
        <tr>
          <td align="center" style="padding:30px 0 40px;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                {% if LOGO_URL %}
                <td>
                  <img src="{{LOGO_URL}}" alt="{{COMPANY_NAME}} Logo" style="display:block;max-width:150px;max-height:80px;">
                </td>
                {% endif %}
                {% if SHOW_COMPANY_NAME_HEADER|default(true) %}
                <td style="padding-left:14px;">
                  <span style="color:{{THEME_HEADING_COLOR|default('#18181b')}};font-size:28px;font-weight:600;letter-spacing:0.5px;">{{COMPANY_NAME}}</span>
                </td>
                {% endif %}
              </tr>
            </table>
          </td>
        </tr>
        {% endif %}

        <!-- MAIN CARD -->
        <tr>
          <td>
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:{{THEME_CARD_BG|default('#ffffff')}};border-radius:16px;border:1px solid {{THEME_BORDER_COLOR|default('#e4e4e7')}};">

              <!-- ACCENT LINE (optional) -->
              {% if THEME_ACCENT_COLOR %}
              <tr>
                <td style="height:4px;background:{{THEME_ACCENT_COLOR}};border-radius:16px 16px 0 0;"></td>
              </tr>
              {% endif %}

              <!-- CONTENT -->
              <tr>
                <td style="padding:48px 44px;">

                  <!-- GREETING -->
                  {% if CONTENT_GREETING %}
                  <p style="margin:0 0 28px;color:{{THEME_HEADING_COLOR|default('#18181b')}};font-size:17px;line-height:1.7;">
                    {{CONTENT_GREETING}}
                  </p>
                  {% endif %}

                  <!-- INTRO -->
                  {% if CONTENT_INTRO %}
                  <p style="margin:0 0 24px;color:{{THEME_TEXT_COLOR|default('#52525b')}};font-size:15px;line-height:1.8;">
                    {{CONTENT_INTRO}}
                  </p>
                  {% endif %}

                  <!-- HIGHLIGHT BOX (optional) -->
                  {% if CONTENT_HIGHLIGHT %}
                  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 28px;">
                    <tr>
                      <td style="background:{{THEME_HIGHLIGHT_BG|default('#fafafa')}};padding:20px 24px;border-radius:12px;border-left:4px solid {{THEME_PRIMARY_COLOR|default('#3b82f6')}};">
                        <p style="margin:0;color:{{THEME_TEXT_COLOR|default('#52525b')}};font-size:14px;line-height:1.7;font-style:italic;">
                          „{{CONTENT_HIGHLIGHT}}"
                        </p>
                      </td>
                    </tr>
                  </table>
                  {% endif %}

                  <!-- BODY PARAGRAPHS -->
                  {{CONTENT_BODY}}

                  <!-- CTA BUTTON (optional) -->
                  {% if CONTENT_CTA_URL and CONTENT_CTA_TEXT %}
                  <table cellpadding="0" cellspacing="0" border="0" style="margin:32px 0;">
                    <tr>
                      <td align="center" style="background:{{THEME_PRIMARY_COLOR|default('#3b82f6')}};border-radius:10px;">
                        <a href="{{CONTENT_CTA_URL}}" 
                           class="mso-button"
                           style="display:inline-block;padding:14px 32px;color:#ffffff;text-decoration:none;font-size:14px;font-weight:600;letter-spacing:0.3px;">
                          {{CONTENT_CTA_TEXT}}
                        </a>
                      </td>
                    </tr>
                  </table>
                  {% endif %}

                  <!-- SIGNATURE -->
                  <table cellpadding="0" cellspacing="0" border="0" style="border-top:1px solid {{THEME_BORDER_COLOR|default('#e4e4e7')}};margin-top:32px;">
                    <tr>
                      <td style="padding-top:24px;">
                        <p style="margin:0 0 4px;color:{{THEME_HEADING_COLOR|default('#18181b')}};font-size:15px;font-weight:600;">{{SENDER_NAME}}</p>
                        {% if SENDER_TITLE %}
                        <p style="margin:0 0 12px;color:{{THEME_MUTED_COLOR|default('#71717a')}};font-size:13px;">{{SENDER_TITLE}}</p>
                        {% endif %}
                        <p style="margin:0;color:{{THEME_MUTED_COLOR|default('#71717a')}};font-size:12px;line-height:1.6;">
                          {{COMPANY_NAME}}<br>
                          {% if COMPANY_URL %}
                          <a href="{{COMPANY_URL}}" style="color:{{THEME_PRIMARY_COLOR|default('#3b82f6')}};text-decoration:none;">{{COMPANY_DOMAIN}}</a>
                          {% endif %}
                        </p>
                      </td>
                    </tr>
                  </table>

                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" style="padding:32px 20px;">
            <p style="margin:0 0 8px;color:{{THEME_MUTED_COLOR|default('#71717a')}};font-size:11px;letter-spacing:0.5px;">
              © {{YEAR}} {{COMPANY_NAME}}
            </p>
            {% if COMPANY_URL %}
            <p style="margin:0;color:{{THEME_MUTED_COLOR|default('#a1a1aa')}};font-size:11px;">
              <a href="{{COMPANY_URL}}/impressum" style="color:{{THEME_MUTED_COLOR|default('#71717a')}};text-decoration:none;">Impressum</a>
              <span style="padding:0 8px;">·</span>
              <a href="{{COMPANY_URL}}/datenschutz" style="color:{{THEME_MUTED_COLOR|default('#71717a')}};text-decoration:none;">Datenschutz</a>
              {% if UNSUBSCRIBE_URL %}
              <span style="padding:0 8px;">·</span>
              <a href="{{UNSUBSCRIBE_URL}}" style="color:{{THEME_MUTED_COLOR|default('#71717a')}};text-decoration:none;">Abmelden</a>
              {% endif %}
            </p>
            {% endif %}
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>

</body>
</html>
