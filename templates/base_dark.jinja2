<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{EMAIL_SUBJECT}}</title>
</head>
<body style="margin:0;padding:0;background-color:#0a0a0f;font-family:'Segoe UI',Roboto,Arial,sans-serif;-webkit-font-smoothing:antialiased;">

<!-- WRAPPER -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0a0a0f;padding:40px 20px;">
  <tr>
    <td align="center">

      <!-- MAIN CONTAINER -->
      <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;">

        <!-- LOGO HEADER -->
        {% if LOGO_URL %}
        <tr>
          <td align="center" style="padding:30px 0 40px;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td>
                  <img src="{{LOGO_URL}}" alt="{{COMPANY_NAME}} Logo" style="display:block;max-width:150px;max-height:80px;">
                </td>
                <td style="padding-left:14px;">
                  <span style="color:#ffffff;font-size:28px;font-weight:600;letter-spacing:0.5px;">{{COMPANY_NAME}}</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {% endif %}

        <!-- MAIN CARD -->
        <tr>
          <td>
            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#18181b;border-radius:16px;border:1px solid #27272a;">

              <!-- GRADIENT ACCENT LINE -->
              <tr>
                <td style="height:4px;background:linear-gradient(90deg,{{THEME_PRIMARY_COLOR|default('#6366f1')}},{{THEME_SECONDARY_COLOR|default('#a855f7')}});border-radius:16px 16px 0 0;"></td>
              </tr>

              <!-- CONTENT -->
              <tr>
                <td style="padding:48px 44px;">

                  <!-- GREETING -->
                  {% if CONTENT_GREETING %}
                  <p style="margin:0 0 28px;color:#fafafa;font-size:17px;line-height:1.7;">
                    {{CONTENT_GREETING}}
                  </p>
                  {% endif %}

                  <!-- INTRO -->
                  {% if CONTENT_INTRO %}
                  <p style="margin:0 0 24px;color:#a1a1aa;font-size:15px;line-height:1.8;">
                    {{CONTENT_INTRO}}
                  </p>
                  {% endif %}

                  <!-- HIGHLIGHT BOX -->
                  {% if CONTENT_HIGHLIGHT %}
                  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 28px;">
                    <tr>
                      <td style="background:linear-gradient(135deg,#1e1b4b 0%,#312e81 100%);padding:20px 24px;border-radius:12px;border-left:4px solid #818cf8;">
                        <p style="margin:0;color:#e0e7ff;font-size:14px;line-height:1.7;font-style:italic;">
                          „{{CONTENT_HIGHLIGHT}}"
                        </p>
                      </td>
                    </tr>
                  </table>
                  {% endif %}

                  <!-- BODY PARAGRAPHS -->
                  {{CONTENT_BODY}}

                  <!-- CTA BUTTON -->
                  {% if CONTENT_CTA_URL and CONTENT_CTA_TEXT %}
                  <table cellpadding="0" cellspacing="0" border="0" style="margin:32px 0;">
                    <tr>
                      <td align="center" style="background:linear-gradient(135deg,{{THEME_PRIMARY_COLOR|default('#6366f1')}} 0%,{{THEME_SECONDARY_COLOR|default('#8b5cf6')}} 100%);border-radius:10px;">
                        <a href="{{CONTENT_CTA_URL}}" 
                           style="display:inline-block;padding:14px 32px;color:#ffffff;text-decoration:none;font-size:14px;font-weight:600;letter-spacing:0.3px;">
                          {{CONTENT_CTA_TEXT}}
                        </a>
                      </td>
                    </tr>
                  </table>
                  {% endif %}

                  <!-- SIGNATURE -->
                  <table cellpadding="0" cellspacing="0" border="0" style="border-top:1px solid #27272a;margin-top:32px;">
                    <tr>
                      <td style="padding-top:24px;">
                        <p style="margin:0 0 4px;color:#fafafa;font-size:15px;font-weight:600;">{{SENDER_NAME}}</p>
                        {% if SENDER_TITLE %}
                        <p style="margin:0 0 12px;color:#71717a;font-size:13px;">{{SENDER_TITLE}}</p>
                        {% endif %}
                        <p style="margin:0;color:#52525b;font-size:12px;line-height:1.6;">
                          {{COMPANY_NAME}}<br>
                          {% if COMPANY_URL %}
                          <a href="{{COMPANY_URL}}" style="color:#6366f1;text-decoration:none;">{{COMPANY_DOMAIN}}</a>
                          {% endif %}
                        </p>
                      </td>
                    </tr>
                  </table>

                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" style="padding:32px 20px;">
            <p style="margin:0 0 8px;color:#52525b;font-size:11px;letter-spacing:0.5px;">
              © {{YEAR}} {{COMPANY_NAME}}
            </p>
            {% if COMPANY_URL %}
            <p style="margin:0;color:#3f3f46;font-size:11px;">
              <a href="{{COMPANY_URL}}/impressum" style="color:#52525b;text-decoration:none;">Impressum</a>
              <span style="color:#3f3f46;padding:0 8px;">·</span>
              <a href="{{COMPANY_URL}}/datenschutz" style="color:#52525b;text-decoration:none;">Datenschutz</a>
              {% if UNSUBSCRIBE_URL %}
              <span style="color:#3f3f46;padding:0 8px;">·</span>
              <a href="{{UNSUBSCRIBE_URL}}" style="color:#52525b;text-decoration:none;">Abmelden</a>
              {% endif %}
            </p>
            {% endif %}
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>

</body>
</html>
